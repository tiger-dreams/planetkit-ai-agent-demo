# ===========================================
# PlanetKit AI Agent Demo - Environment Variables
# ===========================================
# Copy this file to .env and fill in your credentials.

# --- LINE LIFF ---
VITE_LIFF_ID=your-liff-id

# --- PlanetKit Evaluation Environment ---
VITE_PLANETKIT_EVAL_SERVICE_ID=your-eval-service-id
VITE_PLANETKIT_EVAL_API_KEY=your-eval-api-key
VITE_PLANETKIT_EVAL_API_SECRET=your-eval-api-secret

# --- PlanetKit Real (Production) Environment ---
VITE_PLANETKIT_REAL_SERVICE_ID=your-real-service-id
VITE_PLANETKIT_REAL_API_KEY=your-real-api-key
VITE_PLANETKIT_REAL_API_SECRET=your-real-api-secret

# --- PlanetKit Agent Call API ---
PLANETKIT_AGENT_CALL_BASE_URL=your-planetkit-agent-call-base-url
PLANETKIT_AGENT_CALL_MOCK_MODE=false

# --- Gemini AI (for AI Agent) ---
GEMINI_API_KEY=your-gemini-api-key

# --- AI Agent Windows VM Service ---
VITE_RENDER_SERVICE_URL=http://your-windows-vm-ip:3000

# --- LINE Messaging API ---
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret

# --- Vercel Postgres ---
POSTGRES_URL=your-postgres-connection-string

# --- Upstash QStash (for delayed retry scheduling) ---
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-qstash-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-qstash-next-signing-key

# --- Cron Job Security ---
CRON_SECRET=your-cron-secret

# --- Windows VM Server (set in render-service environment) ---
# FRONTEND_URL=https://your-vercel-domain.vercel.app
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# PORT=3000
